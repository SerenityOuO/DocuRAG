# App
APP_ENV=local
APP_NAME=DocuRAG AgentOps
APP_VERSION=0.13.0

# Backend
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Database
POSTGRES_DB=docurag
POSTGRES_USER=docurag
POSTGRES_PASSWORD=docurag
DATABASE_URL=postgresql+psycopg://docurag:docurag@localhost:5432/docurag

# Redis / Qdrant / NATS
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
NATS_URL=nats://localhost:4222

# Auth
JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Phase 10 LLM / VLM provider decision. Set DOCURAG_LLM_PROVIDER= to disable local LLM generation.
DOCURAG_LLM_PROVIDER=ollama
DOCURAG_LLM_BASE_URL=http://127.0.0.1:11434
DOCURAG_LLM_MODEL=qwen3.5:4b
DOCURAG_VLM_PROVIDER=ollama
DOCURAG_VLM_MODEL=qwen3.5:4b

# Phase 11 embedding provider is disabled by default.
DOCURAG_EMBEDDING_PROVIDER=
DOCURAG_EMBEDDING_BASE_URL=http://127.0.0.1:11434
DOCURAG_EMBEDDING_MODEL=qwen3-embedding:0.6b
DOCURAG_EMBEDDING_TIMEOUT_SECONDS=30
DOCURAG_QDRANT_URL=http://127.0.0.1:6333
DOCURAG_QDRANT_COLLECTION=docurag_chunks_v1
DOCURAG_QDRANT_VECTOR_SIZE=1024
DOCURAG_QDRANT_TIMEOUT_SECONDS=10
DOCURAG_RAG_RETRIEVAL_PROVIDER=keyword

# Phase 15 rerank provider is disabled by default.
DOCURAG_RERANK_PROVIDER=
DOCURAG_RERANK_MODEL=BAAI/bge-reranker-base
DOCURAG_RERANK_TOP_K=5
DOCURAG_RERANK_TIMEOUT_SECONDS=30

# Reserved fallback endpoint; not used by the v0.13.0 default path.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_API_KEY=
